#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUNTIME_ROOT="${XDG_RUNTIME_DIR:-/tmp}/niobe-bootstrap"
mkdir -p "${RUNTIME_ROOT}"
chmod 700 "${RUNTIME_ROOT}"

gold=$'\033[38;5;179m'
blue=$'\033[38;5;110m'
green=$'\033[38;5;78m'
red=$'\033[38;5;203m'
reset=$'\033[0m'

cleanup() {
  rm -f "${RUNTIME_ROOT}/lb-inventory.ini"
}
trap cleanup EXIT

prompt_value() {
  local prompt="$1"
  local default_value="${2:-}"
  local value=""
  if [[ -n "${default_value}" ]]; then
    read -r -p "${prompt} [${default_value}]: " value
    printf '%s' "${value:-${default_value}}"
  else
    read -r -p "${prompt}: " value
    printf '%s' "${value}"
  fi
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf '%s\n' "${red}missing command:${reset} $1" >&2
    exit 1
  fi
}

printf '%s\n' "${gold} _      ____  ${reset}"
printf '%s\n' "${gold}| |    | __ ) ${reset}"
printf '%s\n' "${gold}| |    |  _ \\ ${reset}"
printf '%s\n' "${gold}| |___ | |_) |${reset}"
printf '%s\n' "${gold}|_____||____/ ${reset}"
printf '%s\n' "${blue}load balancer bootstrap${reset}"

require_cmd ansible-playbook

LOAD_BALANCER_HOST="$(prompt_value 'Load balancer host or IP')"
CONTROL_PLANE_BACKEND_HOST="$(prompt_value 'Control-plane backend host or IP')"
SSH_USER="$(prompt_value 'SSH username')"
SSH_PORT="$(prompt_value 'SSH port' '22')"
SSH_KEY="$(prompt_value 'SSH private key path' "${HOME}/.ssh/id_ed25519")"
SSH_HARDENED_PORT="$(prompt_value 'Hardened SSH port' '2222')"
CONTROL_PLANE_PORT="$(prompt_value 'Control-plane backend port' '80')"
LB_TLS_CERT_PATH="$(prompt_value 'HAProxy TLS certificate path on the load balancer (optional)' '')"

INVENTORY_FILE="${RUNTIME_ROOT}/lb-inventory.ini"
cat > "${INVENTORY_FILE}" <<EOF
[load_balancer]
lb ansible_host=${LOAD_BALANCER_HOST} ansible_user=${SSH_USER} ansible_port=${SSH_PORT} ansible_ssh_private_key_file=${SSH_KEY}
EOF
chmod 600 "${INVENTORY_FILE}"

ansible-playbook \
  -i "${INVENTORY_FILE}" \
  "${ROOT_DIR}/ops/ansible/bootstrap_lb.yml" \
  --extra-vars "ssh_hardened_port=${SSH_HARDENED_PORT} control_plane_host=${CONTROL_PLANE_BACKEND_HOST} control_plane_port=${CONTROL_PLANE_PORT} lb_tls_cert_path=${LB_TLS_CERT_PATH}"

printf '%s\n' "${green}load balancer bootstrap completed${reset}"
