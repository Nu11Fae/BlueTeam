#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUNTIME_ROOT="${XDG_RUNTIME_DIR:-/tmp}/niobe-bootstrap"
mkdir -p "${RUNTIME_ROOT}"
chmod 700 "${RUNTIME_ROOT}"

gold=$'\033[38;5;179m'
blue=$'\033[38;5;110m'
green=$'\033[38;5;78m'
red=$'\033[38;5;203m'
reset=$'\033[0m'

cleanup() {
  rm -f "${RUNTIME_ROOT}/control-plane.env" "${RUNTIME_ROOT}/inventory.ini"
  unset NIOBE_ENV_CIPHER_PASSWORD || true
}
trap cleanup EXIT

prompt_value() {
  local prompt="$1"
  local default_value="${2:-}"
  local value=""
  if [[ -n "${default_value}" ]]; then
    read -r -p "${prompt} [${default_value}]: " value
    printf '%s' "${value:-${default_value}}"
  else
    read -r -p "${prompt}: " value
    printf '%s' "${value}"
  fi
}

prompt_secret() {
  local prompt="$1"
  local value=""
  read -r -s -p "${prompt}" value
  printf '\n'
  printf '%s' "${value}"
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf '%s\n' "${red}missing command:${reset} $1" >&2
    exit 1
  fi
}

printf '%s\n' "${gold}    _   ___      __        ${reset}"
printf '%s\n' "${gold}   / | / (_)__  / /  ___   ${reset}"
printf '%s\n' "${gold}  /  |/ / / _ \\/ _ \\/ _ \\  ${reset}"
printf '%s\n' "${gold} / /|  / /  __/_.__/\\___/  ${reset}"
printf '%s\n' "${gold}/_/ |_/_/\\___/             ${reset}"
printf '%s\n' "${blue}control plane bootstrap${reset} ${green}lb + frontend/backend rollout${reset}"

require_cmd ansible-playbook
require_cmd openssl
require_cmd rsync

CONTROL_PLANE_HOST="$(prompt_value 'Control-plane host or IP')"
LOAD_BALANCER_HOST="$(prompt_value 'Load balancer host or IP')"
CONTROL_PLANE_BACKEND_HOST="$(prompt_value 'Control-plane backend host for the load balancer' "${CONTROL_PLANE_HOST}")"
SSH_USER="$(prompt_value 'SSH username')"
SSH_PORT="$(prompt_value 'SSH port' '22')"
SSH_KEY="$(prompt_value 'SSH private key path' "${HOME}/.ssh/id_ed25519")"
SSH_HARDENED_PORT="$(prompt_value 'Hardened SSH port' '2222')"
APP_ROOT="$(prompt_value 'Target app root on the control-plane server' '/opt/niobe')"
CONTROL_PLANE_PORT="$(prompt_value 'Control-plane backend port behind the load balancer' '80')"
LB_TLS_CERT_PATH="$(prompt_value 'HAProxy TLS certificate path on the load balancer (optional)' '')"
POSTGRES_DB="$(prompt_value 'PostgreSQL database name' 'digital_audit')"
POSTGRES_USER="$(prompt_value 'PostgreSQL username' 'digital_audit')"
POSTGRES_PASSWORD="$(prompt_secret 'PostgreSQL password: ')"
AUTH_SECRET="$(prompt_secret 'Control-plane auth secret [leave empty for generated]: ')"
ENV_CIPHER_PASSWORD="$(prompt_secret 'OpenSSL env passphrase: ')"

if [[ -z "${AUTH_SECRET}" ]]; then
  AUTH_SECRET="$(openssl rand -hex 32)"
fi

if [[ -z "${ENV_CIPHER_PASSWORD}" ]]; then
  printf '%s\n' "${red}missing OpenSSL env passphrase${reset}" >&2
  exit 64
fi

if [[ "${SSH_USER}" == "root" ]]; then
  printf '%s\n' "${red}rootless docker requires a non-root SSH user on the control-plane host${reset}" >&2
  exit 64
fi

mkdir -p "${ROOT_DIR}/ops/runtime"
chmod 700 "${ROOT_DIR}/ops/runtime"

INVENTORY_FILE="${RUNTIME_ROOT}/inventory.ini"
ENV_FILE="${RUNTIME_ROOT}/control-plane.env"
ENC_FILE="${ROOT_DIR}/ops/runtime/control-plane.env.enc"

cat > "${INVENTORY_FILE}" <<EOF
[control_plane]
control ansible_host=${CONTROL_PLANE_HOST} ansible_user=${SSH_USER} ansible_port=${SSH_PORT} ansible_ssh_private_key_file=${SSH_KEY}

[load_balancer]
lb ansible_host=${LOAD_BALANCER_HOST} ansible_user=${SSH_USER} ansible_port=${SSH_PORT} ansible_ssh_private_key_file=${SSH_KEY}
EOF
chmod 600 "${INVENTORY_FILE}"

cat > "${ENV_FILE}" <<EOF
POSTGRES_DB=${POSTGRES_DB}
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
NIOBE_AUTH_SECRET=${AUTH_SECRET}
NIOBE_API_HOST=0.0.0.0
NIOBE_API_PORT=8080
NIOBE_API_BIND_PORT=8080
NIOBE_HEARTBEAT_TIMEOUT=90
EOF
chmod 600 "${ENV_FILE}"

export NIOBE_ENV_CIPHER_PASSWORD="${ENV_CIPHER_PASSWORD}"
openssl enc -aes-256-cbc -pbkdf2 -salt \
  -in "${ENV_FILE}" \
  -out "${ENC_FILE}" \
  -pass env:NIOBE_ENV_CIPHER_PASSWORD
chmod 600 "${ENC_FILE}"

printf '%s\n' "${green}encrypted env ready:${reset} ${ENC_FILE}"
printf '%s\n' "${green}docker mode:${reset} rootless for ${SSH_USER} with linger enabled"
printf '%s\n' "${green}starting load balancer bootstrap${reset}"

ansible-playbook \
  -i "${INVENTORY_FILE}" \
  "${ROOT_DIR}/ops/ansible/bootstrap_lb.yml" \
  --extra-vars "ssh_hardened_port=${SSH_HARDENED_PORT} control_plane_host=${CONTROL_PLANE_BACKEND_HOST} control_plane_port=${CONTROL_PLANE_PORT} lb_tls_cert_path=${LB_TLS_CERT_PATH}"

printf '%s\n' "${green}starting control plane bootstrap${reset}"

ansible-playbook \
  -i "${INVENTORY_FILE}" \
  "${ROOT_DIR}/ops/ansible/bootstrap_control_plane.yml" \
  --extra-vars "ssh_hardened_port=${SSH_HARDENED_PORT} load_balancer_ip=${LOAD_BALANCER_HOST} app_root=${APP_ROOT}"

unset NIOBE_ENV_CIPHER_PASSWORD
rm -f "${ENV_FILE}"

printf '%s\n' "${green}bootstrap completed${reset}"
