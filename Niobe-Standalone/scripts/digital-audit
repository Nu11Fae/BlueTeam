#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="${PYTHON_BIN:-python3}"
IMAGE_TAG="${NIOBE_AUDIT_IMAGE:-niobe}"
CODEX_BIN="${CODEX_BIN:-codex}"
CLAUDE_BIN="${CLAUDE_BIN:-claude}"
NIOBE_CLAUDE_MODEL="${NIOBE_CLAUDE_MODEL:-sonnet}"
LOCAL_NPM_PREFIX="${HOME}/.niobe/npm-global"
PLATFORM="$(uname -s)"
IS_MACOS=0
[[ "${PLATFORM}" == "Darwin" ]] && IS_MACOS=1
AUDIT_PLATFORM="${NIOBE_AUDIT_PLATFORM:-}"
FORCE_REBUILD="${NIOBE_FORCE_REBUILD:-0}"
COMPLETE_MODE=0
INTERRUPTED=0

if [[ -d "${LOCAL_NPM_PREFIX}/bin" ]]; then
  export PATH="${LOCAL_NPM_PREFIX}/bin:${PATH}"
fi
if (( IS_MACOS )) && [[ -z "${AUDIT_PLATFORM}" ]]; then
  AUDIT_PLATFORM="linux/amd64"
fi

gold=$'\033[38;5;179m'
blue=$'\033[38;5;110m'
green=$'\033[38;5;78m'
red=$'\033[38;5;203m'
yellow=$'\033[38;5;221m'
purple=$'\033[38;5;141m'
reset=$'\033[0m'

show_banner() {
  printf '%s\n' "${gold} _   _ ___ ___  ____  _____${reset}"
  printf '%s\n' "${gold}| \\ | |_ _/ _ \\| __ )| ____|${reset}"
  printf '%s\n' "${gold}|  \\| || | | | |  _ \\|  _|${reset}"
  printf '%s\n' "${gold}| |\\  || | |_| | |_) | |___${reset}"
  printf '%s\n' "${gold}|_| \\_|___\\___/|____/|_____|${reset}"
  printf '%s\n' "${blue}Powered by Cybersecurity Team Tecnolife${reset}"
}

show_help() {
  cat <<'EOF_HELP'
Usage:
  digital-audit login [provider] [--use-device-code]
  digital-audit install [--rebuild]
  digital-audit [target] [options]
  digital-audit api <subcommand> [args]
  digital-audit -h | --help

Description:
  Containerized Digital Audit launcher.
  Authentication is a hard prerequisite. Use `digital-audit login` first.
  On macOS the standalone flow is:
  Docker evidence collection -> host LLM review -> Docker finalization.

Audit options:
  --project NAME            Report label written into the delivery package.
  --client NAME             Client or target company label.
  --llm-provider VALUE      Provider selector: 1/anthropic/claude or 2/openai/codex.
  --standalone              Force local temp-delivery mode.
  --control-plane-url URL   Managed mode control-plane endpoint.
  --agent-key KEY           Managed mode authentication key.
  --use-device-code         Use device authentication when the provider supports it.
  --rebuild                 Rebuild the audit runner image during install.
  --complete                Enable SonarQube and FOSSology analysis (both disabled by default).
  -h, --help                Show this help and exit.

Authentication:
  Provider:
    1. Anthropic (Claude Code)
    2. OpenAI (Codex CLI)
  Press Enter on the provider prompt to select Anthropic / Claude Code.
  OpenAI supports device authentication with `--use-device-code`.
  Claude Code does not expose an equivalent device-code flag; it uses its own login flow.

Output:
  <niobe-root>/temp-delivery/Reports/
  <niobe-root>/temp-delivery/Delivery/
  <niobe-root>/temp-delivery/AI_DA.zip
  <niobe-root>/temp-delivery/AI_DA.zip.asc
  <niobe-root>/temp-delivery/Delivery/AI Technical Intelligence Review.docx
  <niobe-root>/temp-delivery/Delivery/AI Technical Intelligence Review.pdf
  <niobe-root>/temp-delivery/Delivery/Risk Register.xlsx
  <niobe-root>/temp-delivery/Delivery/Compliance Artifact.pdf
  <niobe-root>/temp-delivery/Delivery/OSS Provenance Report (Copyleft Risk).pdf

Model selection:
  Claude Code defaults to the official `sonnet` model alias.
  Override it with `NIOBE_CLAUDE_MODEL=<model-alias-or-id>` when needed.

Examples:
  digital-audit login
  digital-audit login 2 --use-device-code
  digital-audit /path/to/repo --project Intrum --client Intrum
  digital-audit install --rebuild
EOF_HELP
}

retry_hint() {
  printf '\n%s\n' "${red}You have to retry xoxo${reset}" >&2
}

usage_error() {
  local message="$1"
  printf '%s\n\n' "Error: ${message}" >&2
  show_help >&2
  retry_hint
  exit 64
}

runtime_error() {
  local code="$1"
  shift
  printf '%s\n' "Error: $*" >&2
  retry_hint
  exit "${code}"
}

handle_interrupt() {
  INTERRUPTED=1
  printf '\n%s\n' "${red}Execution interrupted by operator.${reset}" >&2
  exit 130
}

trap 'handle_interrupt' INT TERM

info() {
  printf '%s\n' "${blue}$*${reset}"
}

success() {
  printf '%s\n' "${green}$*${reset}"
}

warn() {
  printf '%s\n' "${yellow}$*${reset}"
}

print_path_line() {
  local label_color="$1"
  local label="$2"
  local path_value="$3"
  printf '%s%s%s:\n  %s%s%s\n' "${label_color}" "${label}" "${reset}" "${purple}" "${path_value}" "${reset}"
}

run_checked() {
  local code="$1"
  shift
  local context="$1"
  shift
  local log_file=""
  log_file="$(mktemp)"
  if "$@" >"${log_file}" 2>&1; then
    rm -f "${log_file}"
    return 0
  fi
  local detail=""
  detail="$(sed -n '1,8p' "${log_file}" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g')"
  rm -f "${log_file}"
  if [[ -n "${detail}" ]]; then
    runtime_error "${code}" "${context}. ${detail}"
  fi
  runtime_error "${code}" "${context}"
}

command_exists() {
  local candidate="$1"
  if [[ "${candidate}" == */* ]]; then
    [[ -x "${candidate}" ]]
    return
  fi
  command -v "${candidate}" >/dev/null 2>&1
}

command_path() {
  local candidate="$1"
  if [[ "${candidate}" == */* ]]; then
    printf '%s' "${candidate}"
    return 0
  fi
  command -v "${candidate}"
}

resolve_cli_binary() {
  local binary_name="$1"
  local package_name="$2"
  local local_prefix=""
  if command_exists "${binary_name}"; then
    command_path "${binary_name}"
    return 0
  fi
  local_prefix="${LOCAL_NPM_PREFIX}/bin/${binary_name}"
  if [[ -x "${local_prefix}" ]]; then
    printf '%s' "${local_prefix}"
    return 0
  fi
  if [[ -x "${HOME}/.npm-global/bin/${binary_name}" ]]; then
    printf '%s' "${HOME}/.npm-global/bin/${binary_name}"
    return 0
  fi
  if [[ -x "${HOME}/.local/bin/${binary_name}" ]]; then
    printf '%s' "${HOME}/.local/bin/${binary_name}"
    return 0
  fi
  if command_exists npm; then
    local npm_prefix=""
    npm_prefix="$(npm config get prefix 2>/dev/null || true)"
    if [[ -n "${npm_prefix}" && -x "${npm_prefix}/bin/${binary_name}" ]]; then
      printf '%s' "${npm_prefix}/bin/${binary_name}"
      return 0
    fi
  fi
  return 1
}

set_provider_binary_path() {
  local provider="$1"
  local resolved=""
  case "${provider}" in
    claude)
      resolved="$(resolve_cli_binary "claude" "@anthropic-ai/claude-code" || true)"
      [[ -n "${resolved}" ]] || return 1
      CLAUDE_BIN="${resolved}"
      ;;
    codex)
      resolved="$(resolve_cli_binary "codex" "@openai/codex" || true)"
      [[ -n "${resolved}" ]] || return 1
      CODEX_BIN="${resolved}"
      ;;
    *)
      return 1
      ;;
  esac
  local bin_dir=""
  bin_dir="$(dirname "${resolved}")"
  case ":${PATH}:" in
    *":${bin_dir}:"*) ;;
    *) export PATH="${bin_dir}:${PATH}" ;;
  esac
}

has_arg() {
  local needle="$1"
  shift || true
  local item=""
  for item in "$@"; do
    if [[ "${item}" == "${needle}" ]]; then
      return 0
    fi
  done
  return 1
}

option_value() {
  local flag="$1"
  shift
  while [[ $# -gt 0 ]]; do
    if [[ "$1" == "${flag}" ]]; then
      [[ $# -ge 2 ]] || return 1
      printf '%s' "$2"
      return 0
    fi
    shift
  done
  return 1
}

prompt_choice() {
  local prompt="$1"
  local default_value="$2"
  local value=""
  if [[ ! -t 0 ]]; then
    printf '%s' "${default_value}"
    return
  fi
  printf '%s' "${prompt} [${default_value}]: " >&2
  IFS= read -r value
  printf '%s' "${value:-${default_value}}"
}

prompt_required() {
  local prompt="$1"
  local value=""
  [[ -t 0 ]] || return 1
  printf '%s: ' "${prompt}" >&2
  IFS= read -r value
  printf '%s' "${value}"
}

cleanup_post_scan() {
  info 'Cleaning up temporary artifacts.'
  rm -rf "${ROOT_DIR}/niobe_digital_audit.egg-info" 2>/dev/null || true
  rm -rf "${ROOT_DIR}/.venv" 2>/dev/null || true
  rm -rf "${ROOT_DIR}/.claude" 2>/dev/null || true
  rm -rf "${ROOT_DIR}/.codex" 2>/dev/null || true
  rm -rf "${ROOT_DIR}/reports" 2>/dev/null || true
  find "${ROOT_DIR}" -type d -name '__pycache__' -exec rm -rf {} + 2>/dev/null || true
  rm -rf "${HOME}/.claude" 2>/dev/null || true
  rm -rf "${HOME}/.codex" 2>/dev/null || true
  # Remove only cache/runtime traces, keep installed CLIs and Docker image state by default.
  rm -rf "${HOME}/.docker/buildx/activity" 2>/dev/null || true
  rm -rf "${HOME}/.docker/tmp" 2>/dev/null || true
  rm -rf "${HOME}/.cache/docker" 2>/dev/null || true
  rm -rf "${HOME}/.local/state/docker" 2>/dev/null || true
  if command_exists docker; then
    docker container prune -f >/dev/null 2>&1 || true
    docker network prune -f >/dev/null 2>&1 || true
    docker builder prune -f >/dev/null 2>&1 || true
  fi
  rmdir "${ROOT_DIR}/storage" 2>/dev/null || true
}

prompt_cleanup_docker() {
  [[ -t 0 ]] || return 1
  printf '\n%s' "${blue}Cleansing the whole? wannabe Neverland? [Y/n]: ${reset}" >&2
  local answer=""
  IFS= read -r answer
  case "${answer}" in
    ""|[yY]|[yY][eE][sS]) return 0 ;;
    *) return 1 ;;
  esac
}

full_cleanup_docker() {
  info 'Removing Docker runtime state and rootless user-space traces.'
  if command_exists docker; then
    docker system prune -af --volumes >/dev/null 2>&1 || true
  fi
  if command_exists docker-compose && [[ -f "${ROOT_DIR}/docker-compose.yml" ]]; then
    docker-compose -f "${ROOT_DIR}/docker-compose.yml" --profile analysis down -v >/dev/null 2>&1 || true
  elif command_exists docker && docker compose version >/dev/null 2>&1 && [[ -f "${ROOT_DIR}/docker-compose.yml" ]]; then
    docker compose -f "${ROOT_DIR}/docker-compose.yml" --profile analysis down -v >/dev/null 2>&1 || true
  fi
  systemctl --user disable --now docker.service docker.socket containerd.service >/dev/null 2>&1 || true
  local uid=""
  uid="$(id -u 2>/dev/null || true)"
  [[ -n "${uid}" ]] && rm -f "/run/user/${uid}/docker.sock" 2>/dev/null || true
  rm -rf "${HOME}/.docker" 2>/dev/null || true
  rm -rf "${HOME}/.config/docker" 2>/dev/null || true
  rm -rf "${HOME}/.local/share/docker" 2>/dev/null || true
  rm -rf "${HOME}/.local/state/docker" 2>/dev/null || true
  rm -f "${HOME}/.local/bin/docker" "${HOME}/.local/bin/dockerd-rootless.sh" "${HOME}/.local/bin/dockerd-rootless-setuptool.sh" 2>/dev/null || true
}

detect_package_manager() {
  if command_exists brew; then
    printf '%s' 'brew'
    return
  fi
  if command_exists apt-get; then
    printf '%s' 'apt-get'
    return
  fi
  if command_exists dnf; then
    printf '%s' 'dnf'
    return
  fi
  if command_exists yum; then
    printf '%s' 'yum'
    return
  fi
  printf '%s' ''
}

install_packages() {
  local manager="$1"
  shift
  case "${manager}" in
    brew)
      run_checked 69 "Failed to install required packages with Homebrew" brew install "$@"
      ;;
    apt-get)
      run_checked 69 "Failed to refresh apt metadata" sudo apt-get update
      run_checked 69 "Failed to install required packages with apt-get" sudo apt-get install -y "$@"
      ;;
    dnf)
      run_checked 69 "Failed to install required packages with dnf" sudo dnf install -y "$@"
      ;;
    yum)
      run_checked 69 "Failed to install required packages with yum" sudo yum install -y "$@"
      ;;
    *)
      runtime_error 69 "No supported package manager was detected for automatic installation."
      ;;
  esac
}

install_docker_desktop_macos() {
  local manager=""
  manager="$(detect_package_manager)"
  [[ "${manager}" == "brew" ]] || runtime_error 69 "Docker is required and Homebrew was not detected on this macOS host."
  info 'Docker is not installed. Installing Docker Desktop via Homebrew.'
  run_checked 69 "Failed to install Docker Desktop with Homebrew" brew install --cask docker
}

start_docker_desktop_macos() {
  if [[ -d /Applications/Docker.app ]]; then
    open -ga Docker >/dev/null 2>&1 || open /Applications/Docker.app >/dev/null 2>&1 || true
  fi
}

wait_for_docker() {
  local timeout="${1:-90}"
  local elapsed=0
  while (( elapsed < timeout )); do
    if docker info >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
    ((elapsed+=1))
  done
  return 1
}

install_docker_rhel_like() {
  [[ -f /etc/os-release ]] || runtime_error 69 "Cannot detect OS: /etc/os-release not found."
  # shellcheck disable=SC1091
  source /etc/os-release
  local os_id="${ID:-}"
  local os_major="${VERSION_ID%%.*}"
  local repo_url=""
  local gpg_url=""

  case "${os_id}" in
    rhel|ol)
      repo_url="https://download.docker.com/linux/rhel/docker-ce.repo"
      gpg_url="https://download.docker.com/linux/rhel/gpg"
      ;;
    rocky|almalinux)
      repo_url="https://download.docker.com/linux/rhel/docker-ce.repo"
      gpg_url="https://download.docker.com/linux/rhel/gpg"
      ;;
    centos)
      repo_url="https://download.docker.com/linux/centos/docker-ce.repo"
      gpg_url="https://download.docker.com/linux/centos/gpg"
      ;;
    fedora)
      repo_url="https://download.docker.com/linux/fedora/docker-ce.repo"
      gpg_url="https://download.docker.com/linux/fedora/gpg"
      ;;
    *)
      runtime_error 69 "Unsupported RPM distro for Docker install: ${os_id}. Install Docker manually."
      ;;
  esac

  info "Removing conflicting packages..."
  sudo dnf -y remove docker docker-client docker-client-latest docker-common \
    docker-latest docker-latest-logrotate docker-logrotate docker-engine \
    podman runc 2>/dev/null || true

  info "Installing prerequisites..."
  sudo dnf -y install ca-certificates curl dnf-plugins-core 2>/dev/null \
    || sudo yum -y install ca-certificates curl yum-utils 2>/dev/null \
    || true

  info "Adding Docker repository..."
  sudo dnf config-manager --add-repo "${repo_url}" 2>/dev/null \
    || sudo yum-config-manager --add-repo "${repo_url}" 2>/dev/null \
    || runtime_error 69 "Failed to add Docker repository."

  info "Importing Docker GPG key..."
  sudo mkdir -p /etc/pki/rpm-gpg
  sudo curl -fsSL "${gpg_url}" -o /etc/pki/rpm-gpg/docker-ce.gpg
  sudo rpm --import /etc/pki/rpm-gpg/docker-ce.gpg

  info "Installing Docker Engine..."
  sudo dnf -y install docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin 2>/dev/null \
    || sudo yum -y install docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin 2>/dev/null \
    || runtime_error 69 "Failed to install Docker Engine."

  info "Enabling Docker service..."
  sudo systemctl enable --now docker
  sudo usermod -aG docker "${USER}" 2>/dev/null || true

  command_exists docker || runtime_error 69 "Docker installation completed but 'docker' is still not in PATH."
  success "Docker Engine installed: $(docker --version)"
}

ensure_docker() {
  if ! command_exists docker; then
    if (( IS_MACOS )); then
      install_docker_desktop_macos
    elif [[ -x "${ROOT_DIR}/scripts/install-docker-rootless" ]]; then
      local target_user="${SUDO_USER:-${USER:-}}"
      [[ -n "${target_user}" && "${target_user}" != "root" ]] || runtime_error 69 "Docker rootless installation requires a non-root target user."
      info "Docker is not installed. Installing rootless Docker for ${target_user}."
      run_checked 69 "Failed to install Docker rootless" sudo "${ROOT_DIR}/scripts/install-docker-rootless" "${target_user}"
    else
      local pkg_mgr=""
      pkg_mgr="$(detect_package_manager)"
      if [[ "${pkg_mgr}" == "apt-get" ]]; then
        info 'Docker is not installed. Installing docker.io via apt.'
        install_packages apt-get docker.io
        sudo systemctl enable --now docker 2>/dev/null || true
        sudo usermod -aG docker "${USER}" 2>/dev/null || true
      elif [[ "${pkg_mgr}" == "dnf" || "${pkg_mgr}" == "yum" ]]; then
        info 'Docker is not installed. Installing Docker Engine via official repository.'
        install_docker_rhel_like
      else
        runtime_error 69 "Docker is required but no automatic installer is available on this host. Install Docker manually."
      fi
    fi
  fi

  if docker info >/dev/null 2>&1; then
    success 'Docker engine ready.'
    return
  fi

  if (( IS_MACOS )); then
    info 'Docker Desktop is installed but the daemon is not ready. Starting Docker Desktop.'
    start_docker_desktop_macos
    wait_for_docker 90 || runtime_error 70 "Docker Desktop is installed but the daemon is still not ready. Open Docker Desktop once, accept its terms, then retry."
    success 'Docker engine ready.'
    return
  fi

  runtime_error 70 "Docker is installed but the daemon is not reachable."
}

ensure_python() {
  local required_major=3
  local required_minor=11
  local current_version=""
  if command_exists "${PYTHON_BIN}"; then
    current_version="$("${PYTHON_BIN}" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null || true)"
    if [[ -n "${current_version}" ]]; then
      local major="${current_version%%.*}"
      local minor="${current_version#*.}"
      if (( major >= required_major && minor >= required_minor )); then
        return
      fi
      printf '%s\n' "${yellow}La tua versione di Python3 (${current_version}) è obsoleta, provo ad aggiornarla...${reset}"
    fi
  else
    warn "Python3 not found in PATH."
  fi
  local manager=""
  manager="$(detect_package_manager)"
  [[ -n "${manager}" ]] || runtime_error 72 "Python >= ${required_major}.${required_minor} is required but no package manager was detected for automatic installation."
  info "Installing Python ${required_major}.${required_minor}+."
  case "${manager}" in
    brew)
      run_checked 72 "Failed to install Python with Homebrew" brew install python@3.11
      PYTHON_BIN="$(brew --prefix python@3.11)/bin/python3.11"
      ;;
    apt-get)
      if apt-cache show python3.11 >/dev/null 2>&1; then
        install_packages apt-get python3.11 python3.11-venv python3.11-dev
        PYTHON_BIN="python3.11"
      else
        install_packages apt-get software-properties-common
        run_checked 72 "Failed to add deadsnakes PPA" sudo add-apt-repository -y ppa:deadsnakes/ppa
        run_checked 72 "Failed to refresh apt after PPA" sudo apt-get update
        install_packages apt-get python3.11 python3.11-venv python3.11-dev
        PYTHON_BIN="python3.11"
      fi
      ;;
    dnf)
      install_packages dnf python3.11 python3.11-devel
      PYTHON_BIN="python3.11"
      ;;
    yum)
      install_packages yum python3.11 python3.11-devel
      PYTHON_BIN="python3.11"
      ;;
    *)
      runtime_error 72 "Unsupported package manager for Python installation: ${manager}"
      ;;
  esac
  if ! command_exists "${PYTHON_BIN}"; then
    printf '%s\n' "${red}Fallimento nell'aggiornamento della versione di Python3 a >=${required_major}.${required_minor}. QUIT${reset}"
    exit 72
  fi
  local installed_version=""
  installed_version="$("${PYTHON_BIN}" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null || true)"
  success "Python ${installed_version} ready: $(command_path "${PYTHON_BIN}")"
}

ensure_node_runtime() {
  if command_exists node && command_exists npm; then
    return
  fi
  local manager=""
  manager="$(detect_package_manager)"
  [[ -n "${manager}" ]] || runtime_error 71 "Node.js and npm are required to install the selected provider CLI, but no supported package manager was detected."
  info 'Node.js runtime not detected. Installing Node.js and npm.'
  case "${manager}" in
    brew)
      run_checked 71 "Failed to install Node.js with Homebrew" brew install node
      ;;
    apt-get|dnf|yum)
      install_packages "${manager}" nodejs npm
      ;;
    *)
      runtime_error 71 "Unsupported package manager for Node.js installation: ${manager}"
      ;;
  esac
  command_exists npm || runtime_error 71 "Node.js installation finished but npm is still unavailable."
}

refresh_npm_path() {
  local prefix=""
  prefix="$(npm config get prefix 2>/dev/null || true)"
  if [[ -n "${prefix}" && -d "${prefix}/bin" ]]; then
    case ":${PATH}:" in
      *":${prefix}/bin:"*) ;;
      *) export PATH="${prefix}/bin:${PATH}" ;;
    esac
  fi
  if [[ -d "${LOCAL_NPM_PREFIX}/bin" ]]; then
    case ":${PATH}:" in
      *":${LOCAL_NPM_PREFIX}/bin:"*) ;;
      *) export PATH="${LOCAL_NPM_PREFIX}/bin:${PATH}" ;;
    esac
  fi
  hash -r
}

npm_global_install() {
  local package_name="$1"
  if npm install -g "${package_name}" >/dev/null 2>&1; then
    refresh_npm_path
    return 0
  fi
  mkdir -p "${LOCAL_NPM_PREFIX}"
  export npm_config_prefix="${LOCAL_NPM_PREFIX}"
  export PATH="${LOCAL_NPM_PREFIX}/bin:${PATH}"
  run_checked 71 "Failed to install ${package_name} with npm" npm install -g "${package_name}"
  refresh_npm_path
}

normalize_provider() {
  local raw="${1:-}"
  local normalized=""
  normalized="$(printf '%s' "${raw}" | tr '[:upper:]' '[:lower:]')"
  case "${normalized}" in
    ''|1|anthropic|claude)
      printf '%s' 'claude'
      ;;
    2|openai|codex)
      printf '%s' 'codex'
      ;;
    *)
      return 1
      ;;
  esac
}

provider_label() {
  case "$1" in
    claude) printf '%s' 'Anthropic (Claude Code)' ;;
    codex) printf '%s' 'OpenAI (Codex CLI)' ;;
    *) printf '%s' "$1" ;;
  esac
}

provider_binary() {
  case "$1" in
    claude) printf '%s' "${CLAUDE_BIN}" ;;
    codex) printf '%s' "${CODEX_BIN}" ;;
    *) return 1 ;;
  esac
}

provider_package() {
  case "$1" in
    claude) printf '%s' '@anthropic-ai/claude-code' ;;
    codex) printf '%s' '@openai/codex' ;;
    *) return 1 ;;
  esac
}

ensure_provider_cli() {
  local provider="$1"
  local binary=""
  local label=""
  local package_name=""

  binary="$(provider_binary "${provider}")" || runtime_error 73 "Unsupported LLM provider: ${provider}"
  label="$(provider_label "${provider}")"
  package_name="$(provider_package "${provider}")"

  refresh_npm_path
  set_provider_binary_path "${provider}" >/dev/null 2>&1 || true
  if command_exists "${binary}" || [[ -x "${binary}" ]]; then
    success "${label} ready: $(command_path "${binary}")"
    return
  fi

  info "${label} is not installed. Installing it now."
  ensure_node_runtime
  npm_global_install "${package_name}"
  refresh_npm_path
  set_provider_binary_path "${provider}" >/dev/null 2>&1 || true
  command_exists "${binary}" || [[ -x "${binary}" ]] || runtime_error 71 "${label} was installed but the CLI is still not in PATH."
  success "${label} installed: $(command_path "${binary}")"
}

provider_logged_in() {
  local provider="$1"
  case "${provider}" in
    codex)
      local output=""
      output="$("${CODEX_BIN}" login status 2>&1 || true)"
      if [[ -z "${output}" ]]; then
        return 1
      fi
      if printf '%s' "${output}" | grep -qi 'not logged in\|error\|unauthenticated\|not authenticated'; then
        return 1
      fi
      printf '%s' "${output}" | grep -qi 'logged in\|authenticated\|@'
      ;;
    claude)
      if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        return 0
      fi
      local auth_output=""
      auth_output="$("${CLAUDE_BIN}" auth status 2>/dev/null || true)"
      if [[ -z "${auth_output}" ]]; then
        return 1
      fi
      printf '%s' "${auth_output}" | grep -q '"loggedIn"[[:space:]]*:[[:space:]]*true'
      ;;
    *)
      return 1
      ;;
  esac
}

launch_provider_login() {
  local provider="$1"
  local use_device_code="${2:-0}"
  case "${provider}" in
    codex)
      info 'Starting OpenAI device authentication.'
      "${CODEX_BIN}" login --device-auth
      ;;
    claude)
      if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        success 'ANTHROPIC_API_KEY is set. Skipping interactive login.'
        return
      fi
      printf '\n%s\n' "${blue}Anthropic authentication:${reset}" >&2
      printf '%s\n' '1. Interactive Claude setup (default — handles login, also headless)' >&2
      printf '%s\n' '2. API key' >&2
      local auth_choice=""
      auth_choice="$(prompt_choice 'Choose method' '1')"
      if [[ "${auth_choice}" == "2" ]]; then
        printf '%s' "${blue}Paste your Anthropic API key (sk-ant-...): ${reset}" >&2
        local api_key=""
        read -r api_key
        if [[ -z "${api_key}" ]]; then
          runtime_error 72 "No API key provided."
        fi
        export ANTHROPIC_API_KEY="${api_key}"
        success 'ANTHROPIC_API_KEY set for this session.'
      else
        info 'Per procedere, avvieremo Claude in modalità interattiva per completare l'\''autenticazione.'
        info 'Al termine, esci con /exit e il programma proseguirà automaticamente.'
        printf '%s' "${blue}Continuare? [Y/n]: ${reset}" >&2
        local confirm=""
        IFS= read -r confirm
        case "${confirm}" in
          [nN]*)
            info 'Operazione annullata.'
            exit 0
            ;;
        esac
        "${CLAUDE_BIN}"
        info 'Claude session ended. Checking authentication...'
      fi
      ;;
    *)
      runtime_error 73 "Unsupported login provider: ${provider}"
      ;;
  esac
}

ensure_provider_authenticated_for_audit() {
  local provider="$1"
  local use_device_code="${2:-0}"
  local label=""
  label="$(provider_label "${provider}")"
  ensure_provider_cli "${provider}"
  if provider_logged_in "${provider}"; then
    success "${label} authentication verified."
    return
  fi
  warn "${label} login is required before starting the audit."
  launch_provider_login "${provider}" "${use_device_code}"
  if provider_logged_in "${provider}"; then
    success "${label} authentication verified."
    return
  fi
  runtime_error 72 "${label} login did not complete successfully. Re-run: ./digital-audit login"
}

start_analysis_services() {
  local complete="${1:-0}"
  if (( ! complete )); then
    return 0
  fi
  local compose_file="${ROOT_DIR}/Docker/docker-compose.yml"
  [[ -f "${compose_file}" ]] || return 0

  export NIOBE_TOOL_SONARQUBE=1
  export NIOBE_TOOL_FOSSOLOGY=1

  if command_exists docker && docker compose version >/dev/null 2>&1; then
    info 'Starting local FOSSology service (--complete).'
    docker compose -f "${compose_file}" --profile analysis up -d fossology >/dev/null 2>&1 || warn 'Unable to start local FOSSology service.'
    info 'Starting local SonarQube service (--complete).'
    docker compose -f "${compose_file}" --profile analysis up -d sonarqube >/dev/null 2>&1 || warn 'Unable to start local SonarQube service.'
  elif command_exists docker-compose; then
    info 'Starting local FOSSology service (--complete).'
    docker-compose -f "${compose_file}" --profile analysis up -d fossology >/dev/null 2>&1 || warn 'Unable to start local FOSSology service.'
    info 'Starting local SonarQube service (--complete).'
    docker-compose -f "${compose_file}" --profile analysis up -d sonarqube >/dev/null 2>&1 || warn 'Unable to start local SonarQube service.'
  else
    warn 'Docker Compose not available; skipping local analysis service startup.'
    return 0
  fi

  export FOSSOLOGY_URL="${FOSSOLOGY_URL:-http://127.0.0.1:${FOSSOLOGY_BIND_PORT:-8081}}"
  export SONAR_HOST_URL="${SONAR_HOST_URL:-http://127.0.0.1:${SONAR_BIND_PORT:-9000}}"
}

wait_for_http() {
  local url="$1"
  local timeout="${2:-120}"
  local elapsed=0
  while (( elapsed < timeout )); do
    if curl -fsS -m 5 "${url}" >/dev/null 2>&1; then
      return 0
    fi
    sleep 2
    ((elapsed+=2))
  done
  return 1
}

bootstrap_fossology_token() {
  [[ -n "${FOSSOLOGY_TOKEN:-}" ]] && return 0
  [[ -n "${FOSSOLOGY_URL:-}" ]] || return 1
  wait_for_http "${FOSSOLOGY_URL}" 120 || {
    warn 'FOSSology did not become reachable in time.'
    return 1
  }

  local user="${FOSSOLOGY_USER:-fossy}"
  local password="${FOSSOLOGY_PASSWORD:-fossy}"
  local expires=""
  if command_exists date && date -u -d '+7 days' +%F >/dev/null 2>&1; then
    expires="$(date -u -d '+7 days' +%F)"
  else
    expires="$(python3 - <<'PY'
from datetime import datetime, timedelta, timezone
print((datetime.now(timezone.utc)+timedelta(days=7)).date().isoformat())
PY
)"
  fi

  local response=""
  response="$(curl -fsS -X POST "${FOSSOLOGY_URL}/repo/api/v1/tokens"     -H 'Content-Type: application/x-www-form-urlencoded'     --data-urlencode "username=${user}"     --data-urlencode "password=${password}"     --data-urlencode "token_name=niobe-$(date +%Y%m%d%H%M%S)"     --data-urlencode "token_scope=write"     --data-urlencode "token_expire=${expires}" 2>/dev/null || true)"
  if [[ -z "${response}" ]]; then
    warn 'FOSSology token bootstrap failed; continuing without token.'
    return 1
  fi

  local token=""
  token="$(RESPONSE_JSON="${response}" python3 -c 'import json, os; value=json.loads(os.environ["RESPONSE_JSON"]).get("Authorization",""); print(value.split(" ",1)[1] if value.lower().startswith("bearer ") else value)' 2>/dev/null || true)"
  if [[ -z "${token}" ]]; then
    warn 'FOSSology token bootstrap returned an unexpected payload; continuing without token.'
    return 1
  fi
  export FOSSOLOGY_TOKEN="${token}"
  export FOSSOLOGY_FOLDER_ID="${FOSSOLOGY_FOLDER_ID:-1}"
  success 'FOSSology API token bootstrapped.'
  return 0
}

ensure_image() {
  local rebuild_enabled=0
  case "${FORCE_REBUILD}" in
    1|true|TRUE|yes|YES|on|ON) rebuild_enabled=1 ;;
  esac
  if docker image inspect "${IMAGE_TAG}" >/dev/null 2>&1 && (( ! rebuild_enabled )); then
    success "Audit runner image ready: ${IMAGE_TAG}"
    return
  fi
  if (( rebuild_enabled )); then
    info "Rebuilding audit runner image: ${IMAGE_TAG}"
  else
    info "Building audit runner image: ${IMAGE_TAG}"
  fi
  if [[ -n "${AUDIT_PLATFORM}" ]]; then
    docker build --platform "${AUDIT_PLATFORM}" -f "${ROOT_DIR}/Docker/Dockerfile.audit" -t "${IMAGE_TAG}" "${ROOT_DIR}"
  else
    docker build -f "${ROOT_DIR}/Docker/Dockerfile.audit" -t "${IMAGE_TAG}" "${ROOT_DIR}"
  fi
  success "Audit runner image built successfully: ${IMAGE_TAG}"
}

host_ip() {
  /sbin/ifconfig 2>/dev/null | awk '/inet / && $2 != "127.0.0.1" {print $2; exit}'
}

host_machine_id() {
  ioreg -rd1 -c IOPlatformExpertDevice 2>/dev/null | awk -F '"' '/IOPlatformUUID/ {print $4; exit}'
}

host_boot_id() {
  if [[ -r /proc/sys/kernel/random/boot_id ]]; then
    cat /proc/sys/kernel/random/boot_id
    return
  fi
  if command_exists sysctl && command_exists shasum; then
    sysctl -n kern.boottime 2>/dev/null | tr -d '\n' | shasum -a 256 | awk '{print $1}'
  fi
}

host_monotonic_ns() {
  perl -MTime::HiRes=clock_gettime,CLOCK_MONOTONIC -e 'printf("%.0f\n", clock_gettime(CLOCK_MONOTONIC)*1000000000)'
}

filesystem_source() {
  df -P "$1" 2>/dev/null | awk 'NR==2 {print $1}'
}

filesystem_type() {
  if [[ "${PLATFORM}" == "Darwin" ]]; then
    stat -f '%T' "$1" 2>/dev/null || true
  else
    stat -f -c '%T' "$1" 2>/dev/null || true
  fi
}

path_inode() {
  if [[ "${PLATFORM}" == "Darwin" ]]; then
    stat -f '%i' "$1" 2>/dev/null || true
  else
    stat -c '%i' "$1" 2>/dev/null || true
  fi
}

path_size() {
  if [[ "${PLATFORM}" == "Darwin" ]]; then
    stat -f '%z' "$1" 2>/dev/null || true
  else
    stat -c '%s' "$1" 2>/dev/null || true
  fi
}

path_mode() {
  if [[ "${PLATFORM}" == "Darwin" ]]; then
    stat -f '%Sp' "$1" 2>/dev/null || true
  else
    stat -c '%A' "$1" 2>/dev/null || true
  fi
}

path_mtime() {
  if [[ "${PLATFORM}" == "Darwin" ]]; then
    stat -f '%m' "$1" 2>/dev/null || true
  else
    stat -c '%Y' "$1" 2>/dev/null || true
  fi
}

resolve_target_path() {
  local raw_path="$1"
  [[ -d "${raw_path}" ]] || return 1
  (cd "${raw_path}" && pwd)
}

prompt_target_path() {
  local raw_path=""
  raw_path="$(prompt_required 'Repository path')" || usage_error 'target path required'
  [[ -n "${raw_path}" ]] || usage_error 'target path required'
  local resolved=""
  resolved="$(resolve_target_path "${raw_path}")" || usage_error "Target path not found: ${raw_path}"
  printf '%s' "${resolved}"
}

host_font_mount_args() {
  local -a args=()
  if [[ "${PLATFORM}" == "Darwin" ]]; then
    [[ -d "/System/Library/Fonts" ]] && args+=(-v "/System/Library/Fonts:/usr/local/share/fonts/macos-system:ro")
    [[ -d "/Library/Fonts" ]] && args+=(-v "/Library/Fonts:/usr/local/share/fonts/macos-library:ro")
    [[ -d "${HOME}/Library/Fonts" ]] && args+=(-v "${HOME}/Library/Fonts:/usr/local/share/fonts/macos-user:ro")
  fi
  printf '%s\n' "${args[@]}"

}

common_env_args() {
  local target="$1"
  local start_ns="$2"
  local ip="$(host_ip || true)"
  local fs_source="$(filesystem_source "${target}" || true)"
  local fs_type="$(filesystem_type "${target}" || true)"
  local source_inode="$(path_inode "${target}" || true)"
  local source_size="$(path_size "${target}" || true)"
  local source_mode="$(path_mode "${target}" || true)"
  local source_mtime="$(path_mtime "${target}" || true)"

  ip="${ip//$'
'/ }"
  fs_source="${fs_source//$'
'/ }"
  fs_type="${fs_type//$'
'/ }"
  source_inode="${source_inode//$'
'/ }"
  source_size="${source_size//$'
'/ }"
  source_mode="${source_mode//$'
'/ }"
  source_mtime="${source_mtime//$'
'/ }"
  local tty_name="not-a-tty"
  if [[ -t 0 ]]; then
    tty_name="$(tty)"
  fi

  local -a args=(
    -e "NIOBE_HOSTNAME=$(hostname)"
    -e "NIOBE_IP_ADDRESSES=${ip}"
    -e "NIOBE_HOST_CWD=${PWD}"
    -e "NIOBE_HOST_OS=${PLATFORM}"
    -e "NIOBE_HOST_SHELL=${SHELL:-${0}}"
    -e "NIOBE_HOST_SOURCE=${target}"
    -e "NIOBE_HOST_TARGET=${target}"
    -e "NIOBE_BOOT_ID=$(host_boot_id || true)"
    -e "NIOBE_MACHINE_ID=$(host_machine_id || true)"
    -e "NIOBE_HOST_TTY=${tty_name}"
    -e "NIOBE_HOST_MONOTONIC_NS=${start_ns}"
    -e "NIOBE_RUN_MONOTONIC_START_NS=${start_ns}"
    -e "NIOBE_HOST_RUN_ROOT=${ROOT_DIR}/temp-delivery"
    -e "NIOBE_FILESYSTEM_SOURCE=${fs_source}"
    -e "NIOBE_FSTYPE=${fs_type}"
    -e "NIOBE_FILESYSTEM_TARGET=${target}"
    -e "NIOBE_SOURCE_INODE=${source_inode}"
    -e "NIOBE_SOURCE_SIZE=${source_size}"
    -e "NIOBE_SOURCE_MODE=${source_mode}"
    -e "NIOBE_SOURCE_MTIME=${source_mtime}"
  )

  local forwarded=(SONAR_HOST_URL SONAR_TOKEN FOSSOLOGY_URL FOSSOLOGY_TOKEN FOSSOLOGY_FOLDER_ID NIOBE_AUTH_SECRET DATABASE_URL)
  local name=""
  for name in "${forwarded[@]}"; do
    if [[ -n "${!name:-}" ]]; then
      args+=(-e "${name}=${!name}")
    fi
  done

  printf '%s\n' "${args[@]}"
}

run_prepare() {
  local target="$1"
  local project="$2"
  local client="$3"
  local provider="$4"
  local start_ns="$5"
  local output_root="$6"
  local -a env_args=()
  local -a font_args=()
  local -a platform_args=()
  local -a docker_cmd=(docker run --rm)
  if [[ -n "${AUDIT_PLATFORM}" ]]; then
    platform_args=(--platform "${AUDIT_PLATFORM}")
  fi
  while IFS= read -r -d '' line; do
    env_args+=("${line}")
  done < <(common_env_args "${target}" "${start_ns}")
  while IFS= read -r -d '' line; do
    [[ -n "${line}" ]] && font_args+=("${line}")
  done < <(host_font_mount_args)
  mkdir -p "${output_root}"
  local nvd_dir="${ROOT_DIR}/dependency-check-data"
  mkdir -p "${nvd_dir}"
  if ((${#platform_args[@]})); then
    docker_cmd+=("${platform_args[@]}")
  fi
  if ((${#font_args[@]})); then
    docker_cmd+=("${font_args[@]}")
  fi
  docker_cmd+=(
    -v "${target}:/scan:ro"
    -v "${output_root}:/delivery"
    -v "${nvd_dir}:/opt/dependency-check-data"
    -e "NIOBE_RUN_ROOT=/delivery"
    -e "NIOBE_INNER_CONTAINER=1"
    -e "NIOBE_APP_ROOT=/app"
  )
  if ((${#env_args[@]})); then
    docker_cmd+=("${env_args[@]}")
  fi
  docker_cmd+=(
    "${IMAGE_TAG}"
    python -m Python3.cli prepare /scan --project "${project}" --client "${client}" --standalone --llm-provider "${provider}"
  )
  "${docker_cmd[@]}"
}

run_finalize() {
  local target="$1"
  local provider="$2"
  local start_ns="$3"
  local end_ns="$4"
  local output_root="$5"
  local -a env_args=()
  local -a font_args=()
  local -a platform_args=()
  local -a docker_cmd=(docker run --rm)
  if [[ -n "${AUDIT_PLATFORM}" ]]; then
    platform_args=(--platform "${AUDIT_PLATFORM}")
  fi
  while IFS= read -r -d '' line; do
    env_args+=("${line}")
  done < <(common_env_args "${target}" "${start_ns}")
  while IFS= read -r -d '' line; do
    [[ -n "${line}" ]] && font_args+=("${line}")
  done < <(host_font_mount_args)
  env_args+=(-e "NIOBE_RUN_MONOTONIC_END_NS=${end_ns}")
  mkdir -p "${output_root}"
  if ((${#platform_args[@]})); then
    docker_cmd+=("${platform_args[@]}")
  fi
  if ((${#font_args[@]})); then
    docker_cmd+=("${font_args[@]}")
  fi
  docker_cmd+=(
    -v "${target}:/scan:ro"
    -v "${output_root}:/delivery"
    -e "NIOBE_RUN_ROOT=/delivery"
    -e "NIOBE_INNER_CONTAINER=1"
    -e "NIOBE_APP_ROOT=/app"
  )
  if ((${#env_args[@]})); then
    docker_cmd+=("${env_args[@]}")
  fi
  docker_cmd+=(
    "${IMAGE_TAG}"
    python -m Python3.cli finalize /delivery --llm-provider "${provider}"
  )
  "${docker_cmd[@]}"
}

prompt_provider() {
  printf '%s\n' 'Provider:' >&2
  printf '%s\n' '1. Anthropic (Claude Code)' >&2
  printf '%s\n' '2. OpenAI (Codex CLI)' >&2
  local choice=""
  local provider=""
  choice="$(prompt_choice 'Choose provider' '1')"
  if ! provider="$(normalize_provider "${choice}")"; then
    usage_error "Unsupported LLM provider: ${choice}"
  fi
  printf '%s' "${provider}"
}

prompt_activity_type() {
  printf '%s\n' '' >&2
  printf '%s\n' "${blue}Tipo di attività:${reset}" >&2
  printf '%s\n' '1. Audit' >&2
  printf '%s\n' '2. Digital-Audit (default)' >&2
  printf '%s\n' '3. Due Diligence' >&2
  printf '%s\n' '4. Check di SSDLC' >&2
  local choice=""
  choice="$(prompt_choice 'Scegli attività' '2')"
  case "${choice}" in
    1) printf '%s' 'Audit' ;;
    3) printf '%s' 'Due Diligence' ;;
    4) printf '%s' 'Check di SSDLC' ;;
    *) printf '%s' 'Digital-Audit' ;;
  esac
}

ensure_pip_deps() {
  local venv_dir="${ROOT_DIR}/.venv"
  if [[ -f "${venv_dir}/bin/python" ]]; then
    PYTHON_BIN="${venv_dir}/bin/python"
    export PATH="${venv_dir}/bin:${PATH}"
    if "${PYTHON_BIN}" -c "import Python3, typer" >/dev/null 2>&1; then
      return
    fi
  fi
  info 'Installing Python dependencies (creating virtual environment).'
  "${PYTHON_BIN}" -m venv "${venv_dir}" 2>/dev/null     || runtime_error 72 "Failed to create virtual environment at ${venv_dir}."
  PYTHON_BIN="${venv_dir}/bin/python"
  export PATH="${venv_dir}/bin:${PATH}"
  "${PYTHON_BIN}" -m pip install --quiet --break-system-packages --upgrade pip 2>/dev/null || true
  "${PYTHON_BIN}" -m pip install --quiet --break-system-packages -e "${ROOT_DIR}"     || runtime_error 72 "Failed to install Python dependencies. Run: ${PYTHON_BIN} -m pip install --break-system-packages -e ${ROOT_DIR}"
  success 'Python dependencies installed.'
}

extract_tool_counts() {
  local summary_path="$1"
  if [[ ! -f "${summary_path}" ]]; then
    printf "%s %s\n" 0 0
    return
  fi
  "${PYTHON_BIN}" - "${summary_path}" <<"EOF"
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    payload = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    print("0 0")
    raise SystemExit(0)

ok = 0
failed = 0
for item in (payload.get("tool_results") or {}).values():
    if not isinstance(item, dict):
        continue
    if item.get("skipped"):
        continue
    if item.get("ok"):
        ok += 1
    else:
        failed += 1
print(f"{ok} {failed}")
EOF
}

run_llm() {
  local provider="$1"
  local target="$2"
  local prompt_path="$3"
  local output_path="$4"
  local task_label="${5:-LLM task}"
  local announce="${6:-0}"
  local command_log=""
  local rc=0
  local pid=0

  if ! provider="$(normalize_provider "${provider}")"; then
    runtime_error 73 "Unsupported LLM provider: ${provider}"
  fi

  command_log="$(mktemp)"
  rm -f "${output_path}"
  if [[ "${announce}" == "1" ]]; then
    info "${task_label} started."
    info "Running..."
  fi
  case "${provider}" in
    codex)
      "${CODEX_BIN}" exec --skip-git-repo-check -C "${target}" -o "${output_path}" - < "${prompt_path}" 2>"${command_log}" &
      pid=$!
      ;;
    claude)
      (cd "${target}" && ANTHROPIC_MODEL="${NIOBE_CLAUDE_MODEL}" "${CLAUDE_BIN}" --model "${NIOBE_CLAUDE_MODEL}" -p "Read the complete prompt from stdin and respond with the requested output only." < "${prompt_path}") > "${output_path}" 2>"${command_log}" &
      pid=$!
      ;;
  esac
  while kill -0 "${pid}" 2>/dev/null; do
    if (( INTERRUPTED )); then
      kill "${pid}" 2>/dev/null || true
      wait "${pid}" 2>/dev/null || true
      rm -f "${command_log}"
      exit 130
    fi
    sleep 2
  done
  set +e
  wait "${pid}"
  rc=$?
  set -e
  if (( INTERRUPTED )) || [[ "${rc}" -eq 130 ]]; then
    rm -f "${command_log}"
    exit 130
  fi
  if [[ "${rc}" -ne 0 ]]; then
    local detail=""
    detail="$(sed -n '1,8p' "${command_log}" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g')"
    rm -f "${command_log}"
    runtime_error 73 "${task_label} failed${detail:+. ${detail}}"
  fi
  rm -f "${command_log}"
  [[ -s "${output_path}" ]] || runtime_error 73 "${task_label} completed without producing an output file."
}

print_install_summary() {
  success 'Docker installation check completed successfully.'
  if command_exists "${CODEX_BIN}"; then
    success "OpenAI (Codex CLI) available: $(command_path "${CODEX_BIN}")"
  else
    warn 'OpenAI (Codex CLI) not detected.'
  fi
  if command_exists "${CLAUDE_BIN}"; then
    success "Anthropic (Claude Code) available: $(command_path "${CLAUDE_BIN}")"
  else
    warn 'Anthropic (Claude Code) not detected.'
  fi
}

run_standalone() {
  local target="$1"
  shift
  local project_name=""
  local client_name=""
  local provider="${NIOBE_LLM_PROVIDER:-}"
  local use_device_code="${NIOBE_USE_DEVICE_CODE:-0}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project)
        [[ $# -ge 2 ]] || usage_error '--project requires a value'
        project_name="$2"
        shift 2
        ;;
      --client)
        [[ $# -ge 2 ]] || usage_error '--client requires a value'
        client_name="$2"
        shift 2
        ;;
      --llm-provider)
        [[ $# -ge 2 ]] || usage_error '--llm-provider requires a value'
        provider="$2"
        shift 2
        ;;
      --use-device-code)
        use_device_code=1
        shift
        ;;
      --control-plane-url|--agent-key)
        runtime_error 75 'Managed mode (control plane) is not yet supported in this flow. Use --standalone.'
        ;;
      -h|--help)
        show_help
        exit 0
        ;;
      *)
        usage_error "Unsupported argument: $1"
        ;;
    esac
  done

  if [[ -z "${provider}" && -t 0 ]]; then
    provider="$(prompt_provider)"
  fi
  provider="$(normalize_provider "${provider:-}")" || usage_error "Unsupported LLM provider: ${provider}"

  local activity_type="Digital-Audit"
  if [[ -t 0 ]]; then
    activity_type="$(prompt_activity_type)"
  fi
   export NIOBE_ACTIVITY_TYPE="${activity_type}"

  if [[ -z "${project_name}" && -t 0 ]]; then
    project_name="$(prompt_choice 'Project name' "$(basename "${target}")")"
  fi
  if [[ -z "${client_name}" && -t 0 ]]; then
    client_name="$(prompt_choice 'Client name' "$(basename "${target}")")"
  fi
  [[ -n "${project_name}" ]] || usage_error '--project is required'
  [[ -n "${client_name}" ]] || usage_error '--client is required'

  ensure_provider_authenticated_for_audit "${provider}" "${use_device_code}"
  ensure_python
  ensure_pip_deps
  ensure_docker
  start_analysis_services "${COMPLETE_MODE}"
  bootstrap_fossology_token || true
  ensure_image


  local output_root="${ROOT_DIR}/temp-delivery"
  local start_ns=""
  start_ns="$(host_monotonic_ns)"
  local runtime_root="${output_root}/.runtime"
  local prompt_path="${runtime_root}/llm-prompt.md"
  local llm_output_path="${runtime_root}/llm-debrief.md"
  local risk_register_prompt_path="${runtime_root}/risk-register-prompt.md"
  local risk_register_output_path="${runtime_root}/risk-register.findings.json"
  local summary_path="${runtime_root}/audit-summary.json"
  local delivery_root="${output_root}/Delivery"
  local ok_tools=0
  local failed_tools=0

  info 'Starting evidence collection.'
  run_prepare "${target}" "${project_name}" "${client_name}" "${provider}" "${start_ns}" "${output_root}"

  if [[ -f "${summary_path}" ]]; then
    read -r ok_tools failed_tools < <(extract_tool_counts "${summary_path}")
  fi

  [[ -f "${prompt_path}" ]] || runtime_error 74 "LLM prompt was not generated: ${prompt_path}"

  info "Running..."
  printf '\n'
  printf '%s\n' "${blue}Gate 1: Normalizzazione started...${reset}"
  printf '%s\n' "${green}Gate 1: Normalizzazione ended.${reset}"

  printf '%s\n' "${blue}Gate 2: Clustering started...${reset}"
  printf '%s\n' "${green}Gate 2: Clustering ended.${reset}"

  printf '%s\n' "${blue}Gate 3: Triage started...${reset}"
  run_llm "${provider}" "${target}" "${prompt_path}" "${llm_output_path}" "AI Technical Intelligence Review" 1
  if [[ -f "${risk_register_prompt_path}" ]]; then
    run_llm "${provider}" "${target}" "${risk_register_prompt_path}" "${risk_register_output_path}" "Risk register" 0
  fi
  printf '%s\n' "${green}Gate 3: Triage ended.${reset}"

  local end_ns=""
  end_ns="$(host_monotonic_ns)"
  printf '%s\n' "${blue}Gate 4: Reporting started...${reset}"
  run_finalize "${target}" "${provider}" "${start_ns}" "${end_ns}" "${output_root}"
  printf '%s\n' "${green}Gate 4: Reporting ended.${reset}"

  printf '\n'
  printf '%s\n' "${gold}Digital Audit Summary${reset}"
  print_path_line "${green}" "Target" "${target}"
  printf '%s\n' "${green}Provider${reset}: $(provider_label "${provider}")"
  printf '%s\n' "${green}Tools completed successfully${reset}: ${ok_tools}"
  printf '%s\n' "${yellow}Tools failed${reset}: ${failed_tools}"
  print_path_line "${green}" "Reports directory" "${output_root}/Reports"
  print_path_line "${green}" "Delivery directory" "${delivery_root}"
  print_path_line "${green}" "Word report" "${delivery_root}/AI Technical Intelligence Review.docx"
  print_path_line "${green}" "PDF report" "${delivery_root}/AI Technical Intelligence Review.pdf"
  print_path_line "${green}" "Risk register workbook" "${delivery_root}/Risk Register.xlsx"
  print_path_line "${green}" "Compliance artifact" "${delivery_root}/Compliance Artifact.pdf"
  print_path_line "${green}" "OSS provenance report" "${delivery_root}/OSS Provenance Report (Copyleft Risk).pdf"
  print_path_line "${green}" "Signatures" "${delivery_root}/signatures"
  print_path_line "${green}" "Evidence bundle" "${output_root}/AI_DA.zip"
  print_path_line "${green}" "Evidence bundle signature" "${output_root}/AI_DA.zip.asc"
  cleanup_post_scan
  if prompt_cleanup_docker; then
    full_cleanup_docker
  fi
}

strip_launcher_only_flags() {
  local -a kept=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --complete)
        COMPLETE_MODE=1
        shift
        ;;
      *)
        kept+=("$1")
        shift
        ;;
    esac
  done
  if [[ ${#kept[@]} -gt 0 ]]; then
    printf '%s\n' "${kept[@]}"
  fi
}

main() {
  cd "${ROOT_DIR}"

  case "${1:-}" in
    -h|--help|help)
      show_banner
      printf '\n'
      show_help
      exit 0
      ;;
  esac

  case "${1:-}" in
    install)
      show_banner
      if has_arg '--rebuild' "$@"; then
        FORCE_REBUILD=1
      fi
      if has_arg '--complete' "$@"; then
        COMPLETE_MODE=1
      fi
      ensure_python
      ensure_docker
      ensure_image
      print_install_summary
      ;;
    login)
      show_banner
      shift
      local provider=""
      local use_device_code=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --use-device-code)
            use_device_code=1
            shift
            ;;
          -h|--help)
            show_help
            exit 0
            ;;
          *)
            if [[ -z "${provider}" ]]; then
              provider="$1"
              shift
            else
              usage_error "Unsupported login argument: $1"
            fi
            ;;
        esac
      done
      if [[ -z "${provider}" && -t 0 ]]; then
        provider="$(prompt_provider)"
      fi
      provider="$(normalize_provider "${provider:-}")" || usage_error "Unsupported login provider: ${provider}"
      ensure_provider_cli "${provider}"
      if provider_logged_in "${provider}"; then
        success "$(provider_label "${provider}") is already authenticated."
        exit 0
      fi
      launch_provider_login "${provider}" "${use_device_code}"
      if provider_logged_in "${provider}"; then
        success "$(provider_label "${provider}") login completed successfully."
        exit 0
      fi
      runtime_error 72 "$(provider_label "${provider}") login did not complete successfully."
      ;;
    api)
      exec "${PYTHON_BIN}" -m Python3.cli "$@"
      ;;
    audit)
      shift
      local target=""
      if [[ $# -gt 0 && "${1:-}" != -* ]]; then
        target="$(resolve_target_path "$1")" || usage_error "Target path not found: $1"
        shift
      else
        target="$(prompt_target_path)"
      fi
      show_banner
      local -a launcher_args=()
      while IFS= read -r line; do
        launcher_args+=("${line}")
      done < <(strip_launcher_only_flags "$@")
      run_standalone "${target}" "${launcher_args[@]}"
      ;;
    "")
      if [[ ! -t 0 ]]; then
        usage_error 'target path required'
      fi
      show_banner
      local provider="${NIOBE_LLM_PROVIDER:-}"
      if [[ -z "${provider}" && -t 0 ]]; then
        provider="$(prompt_provider)"
      fi
      provider="$(normalize_provider "${provider:-}")" || usage_error "Unsupported LLM provider: ${provider}"
      local target=""
      target="$(prompt_target_path)"
      local -a launcher_args=("--llm-provider" "${provider}")
      while IFS= read -r line; do
        [[ -n "${line}" ]] && launcher_args+=("${line}")
      done < <(strip_launcher_only_flags)
      run_standalone "${target}" "${launcher_args[@]}"
      ;;
    *)
      local target=""
      if [[ "${1:-}" != -* ]]; then
        target="$(resolve_target_path "$1")" || usage_error "Target path not found: $1"
        shift
      else
        target="$(prompt_target_path)"
      fi
      show_banner
      local -a launcher_args=()
      while IFS= read -r line; do
        launcher_args+=("${line}")
      done < <(strip_launcher_only_flags "$@")
      run_standalone "${target}" "${launcher_args[@]}"
      ;;
  esac
}

main "$@"
