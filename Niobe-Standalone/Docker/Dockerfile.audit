FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends bash build-essential ca-certificates curl git gnupg default-jre-headless fontconfig fonts-dejavu-core fonts-liberation2 fonts-noto-core libcairo2 libffi-dev libgdk-pixbuf-2.0-0 libharfbuzz-subset0 libicu-dev libjpeg62-turbo libopenjp2-7 libpango-1.0-0 libpangocairo-1.0-0 libreoffice-writer pandoc pkg-config shared-mime-info unzip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml README.md ./
COPY Python3/ Python3/
COPY LLMs/ LLMs/
COPY templates/ templates/
COPY scripts/ scripts/
COPY ops/ ops/

ARG GITLEAKS_VERSION=8.28.0

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir . opentimestamps-client \
    && python -m venv /opt/semgrep \
    && /opt/semgrep/bin/pip install --no-cache-dir --upgrade pip \
    && /opt/semgrep/bin/pip install --no-cache-dir semgrep==1.157.0 \
    && python -m venv /opt/scancode \
    && /opt/scancode/bin/pip install --no-cache-dir --upgrade pip \
    && /opt/scancode/bin/pip install --no-cache-dir scancode-toolkit==32.5.0 \
    && ln -sf /opt/semgrep/bin/semgrep /usr/local/bin/semgrep \
    && ln -sf /opt/scancode/bin/scancode /usr/local/bin/scancode \
    && curl -sSfL https://raw.githubusercontent.com/anchore/syft/main/install.sh | sh -s -- -b /usr/local/bin \
    && curl -fsSL "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_linux_x64.tar.gz" -o /tmp/gitleaks.tar.gz \
    && tar -xzf /tmp/gitleaks.tar.gz -C /usr/local/bin gitleaks \
    && chmod +x /usr/local/bin/gitleaks \
    && rm -f /tmp/gitleaks.tar.gz \
    && curl -fsSL https://binaries.sonarsource.com/Distribution/sonar-scanner-cli/sonar-scanner-cli-6.2.1.4610-linux-x64.zip -o /tmp/sonar-scanner.zip \
    && unzip -qo /tmp/sonar-scanner.zip -d /opt \
    && ln -s /opt/sonar-scanner-6.2.1.4610-linux-x64/bin/sonar-scanner /usr/local/bin/sonar-scanner \
    && rm -f /tmp/sonar-scanner.zip \
    && ln -sf /app/templates/fontconfig/niobe-font-aliases.conf /etc/fonts/conf.d/60-niobe-font-aliases.conf \
    && if ls /app/templates/fonts/*.ttf >/dev/null 2>&1; then \
         cp /app/templates/fonts/*.ttf /usr/share/fonts/truetype/ && fc-cache -f; \
       fi

# --- OWASP Dependency-Check ---
ARG DEPCHECK_VERSION=12.1.0
RUN curl -sSL "https://github.com/jeremylong/DependencyCheck/releases/download/v${DEPCHECK_VERSION}/dependency-check-${DEPCHECK_VERSION}-release.zip" -o /tmp/dc.zip \
    && unzip -q /tmp/dc.zip -d /opt \
    && ln -sf /opt/dependency-check/bin/dependency-check.sh /usr/local/bin/dependency-check \
    && rm /tmp/dc.zip

# Copy pre-downloaded NVD data (avoids slow download + rate limiting at build time)
COPY dependency-check-data/ /opt/dependency-check-data/

WORKDIR /workspace
